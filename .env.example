# ── Supabase (required for real auth + database) ────────────────────────────
# From your Supabase project: Settings → API
#   Project URL      → NEXT_PUBLIC_SUPABASE_URL   (https://xxxx.supabase.co)
#   anon / public key → NEXT_PUBLIC_SUPABASE_ANON_KEY
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# While these are unset the app runs in DEMO MODE:
# in-memory data + dummy login with the seeded test credentials.
